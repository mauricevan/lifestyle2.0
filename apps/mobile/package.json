{
  "name": "@rpm/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "build:android": "eas build --profile development --platform android",
    "build:ios": "eas build --profile development --platform ios",
    "build:ios:sim": "eas build --profile development-simulator --platform ios",
    "eas:login": "eas login",
    "eas:init": "eas init",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"lint pending\"",
    "test": "echo \"mobile tests pending\"",
    "eas-build-pre-install": "corepack enable"
  },
  "dependencies": {
    "@expo/metro-runtime": "~57.0.3",
    "@kingstinct/react-native-healthkit": "^14.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@rpm/ep-engine": "workspace:*",
    "@rpm/shared-types": "workspace:*",
    "@rpm/wearable-adapter": "workspace:*",
    "@supabase/supabase-js": "^2.49.8",
    "expo": "~57.0.4",
    "expo-build-properties": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-dev-client": "~57.0.5",
    "expo-health-connect": "^0.1.1",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-speech": "~57.0.0",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-ble-plx": "^3.5.0",
    "react-native-health-connect": "^3.5.0",
    "react-native-nitro-modules": "^0.35.10",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^20.5.1",
    "typescript": "~6.0.3"
  }
}
